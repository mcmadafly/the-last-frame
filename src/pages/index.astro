---
import BaseLayout from "../layouts/BaseLayout.astro";

const FEATURED = {
  youtubeId: "UdRkVQVoM1U",
  channelUrl: "https://www.youtube.com/@SonyPictures",
} as const;
---

<BaseLayout title="The Last Frame" description="Trailers and upcoming releases.">
  <main class="stage">
    <div class="inner">
      <header class="brand">
        <h1 class="brand-heading">
          <a class="wordmark-link" href="/">
            <img
              class="logo-img"
              src="/the-last-frame-logo.svg"
              alt="The Last Frame"
              width="196"
              height="74"
              loading="eager"
              decoding="async"
            />
          </a>
        </h1>
      </header>

      <div class="rule" aria-hidden="true"></div>

      <p class="upcoming">
        <span class="upcoming-dot" aria-hidden="true"></span>
        Upcoming release
      </p>

      <div class="screen">
        <div class="screen-bezel">
          <div class="screen-glare" aria-hidden="true"></div>
          <div class="screen-video">
            <iframe
              title="Featured trailer on YouTube"
              src={`https://www.youtube-nocookie.com/embed/${FEATURED.youtubeId}?rel=0&modestbranding=1`}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </div>

      <p class="credit">
        Official embed ·
        <a class="text-link" href={FEATURED.channelUrl} target="_blank" rel="noopener noreferrer">Sony Pictures on YouTube</a>
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .stage {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 4vw, 1.5rem) clamp(2rem, 5vw, 3rem);
  }

  .inner {
    width: 100%;
    max-width: 40rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .brand-heading {
    margin: 0;
    line-height: 0;
  }

  .wordmark-link {
    display: inline-block;
    text-decoration: none;
    color: inherit;
    border: none;
    outline: none;
  }

  .wordmark-link:focus-visible {
    border-radius: 8px;
    box-shadow: 0 0 0 2px #08080a, 0 0 0 4px rgba(201, 162, 39, 0.65);
  }

  .logo-img {
    display: block;
    width: min(100%, 240px);
    max-width: 100%;
    height: auto;
    /* intrinsic 196×74 — prevent runaway scaling */
    max-height: 92px;
  }

  .rule {
    width: min(10rem, 45vw);
    height: 1px;
    margin: clamp(1.5rem, 4vw, 2.25rem) 0;
    align-self: center;
    background: linear-gradient(90deg, transparent, rgba(201, 162, 39, 0.35), transparent);
  }

  .upcoming {
    margin: 0 0 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #8a847a;
  }

  .upcoming-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #c9a227;
    box-shadow: 0 0 8px rgba(201, 162, 39, 0.4);
    flex-shrink: 0;
  }

  .screen {
    width: 100%;
    max-width: 100%;
  }

  .screen-bezel {
    position: relative;
    border-radius: 6px;
    padding: 3px;
    background: linear-gradient(145deg, #2a2824 0%, #12100e 50%, #1a1814 100%);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.06) inset,
      0 24px 48px -12px rgba(0, 0, 0, 0.65);
  }

  .screen-glare {
    pointer-events: none;
    position: absolute;
    inset: 3px;
    border-radius: 4px;
    background: linear-gradient(
      125deg,
      rgba(255, 255, 255, 0.05) 0%,
      transparent 40%,
      transparent 100%
    );
    z-index: 1;
  }

  .screen-video {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 4px;
    overflow: hidden;
    background: #000;
    z-index: 0;
  }

  .screen-video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .credit {
    margin: 1.1rem 0 0;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: #6b6560;
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
    }
  }
</style>
