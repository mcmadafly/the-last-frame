---
import BaseLayout from "../layouts/BaseLayout.astro";

const FEATURED = {
  youtubeId: "UdRkVQVoM1U",
  channelUrl: "https://www.youtube.com/@SonyPictures",
} as const;
---

<BaseLayout title="The Last Frame" description="The best of sci-fi and horror — upcoming releases and trailers.">
  <div class="wrap">
    <header class="brand-block">
      <a class="logo-link" href="/" aria-label="The Last Frame home">
        <svg class="logo-mark" viewBox="0 0 56 56" aria-hidden="true">
          <rect width="56" height="56" rx="8" fill="#171717" stroke="#262626" stroke-width="1"></rect>
          <rect x="14" y="16" width="28" height="20" rx="2" fill="#0a0a0a" stroke="#404040" stroke-width="1"></rect>
          <path d="M24 22l10 6.5-10 6.5V22z" fill="#fafafa"></path>
        </svg>
        <span class="logo-type">The Last Frame</span>
      </a>

      <p class="tagline">the best of scifi and horror</p>
    </header>

    <div class="spacer" aria-hidden="true"></div>

    <p class="upcoming-label">Upcoming release</p>

    <div class="video">
      <iframe
        title="Featured trailer on YouTube"
        src={`https://www.youtube-nocookie.com/embed/${FEATURED.youtubeId}?rel=0&modestbranding=1`}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>

    <p class="fineprint">
      Official embed ·
      <a href={FEATURED.channelUrl} target="_blank" rel="noopener noreferrer">Sony Pictures on YouTube</a>
    </p>
  </div>
</BaseLayout>

<style>
  .wrap {
    max-width: 56rem;
    margin: 0 auto;
    padding: clamp(2rem, 6vw, 3.5rem) clamp(1.25rem, 4vw, 2rem) 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .brand-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .logo-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    text-decoration: none;
    color: inherit;
  }

  .logo-mark {
    width: 3.5rem;
    height: 3.5rem;
    flex-shrink: 0;
  }

  .logo-type {
    font-weight: 600;
    font-size: clamp(1.35rem, 3.5vw, 1.75rem);
    letter-spacing: -0.03em;
    color: #fafafa;
  }

  .tagline {
    margin: 0;
    font-size: clamp(0.95rem, 2.2vw, 1.1rem);
    font-weight: 400;
    color: #a3a3a3;
    letter-spacing: 0.02em;
  }

  .spacer {
    width: 100%;
    height: clamp(2rem, 6vw, 3.5rem);
    flex-shrink: 0;
  }

  .upcoming-label {
    margin: 0 0 1rem;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: #525252;
    width: 100%;
    max-width: 42rem;
  }

  .video {
    width: 100%;
    max-width: 42rem;
    position: relative;
    aspect-ratio: 16 / 9;
    background: #000;
    border-radius: 2px;
    overflow: hidden;
    box-shadow: 0 0 0 1px #262626;
  }

  .video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .fineprint {
    margin: 1rem 0 0;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: #525252;
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
    }
  }
</style>
