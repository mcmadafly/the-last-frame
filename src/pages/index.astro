---
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * Chronological 2026 US dates.
 * Posters: TMDB CDN (`w780`), except Evil Dead Burn — no poster on TMDB yet (Apr 2026).
 */
const TMDB_IMG = "https://image.tmdb.org/t/p/w780";

const UPCOMING = [
  { title: "Weekend at the End of the World", date: "April 20, 2026", posterPath: "lmkxctsfitUnLTbqLJHFjGJr5ru.jpg" },
  { title: "Mortal Kombat II", date: "May 8, 2026", posterPath: "io7wVbm9VKaanIcuAymCDy9dmjU.jpg" },
  { title: "The Mandalorian and Grogu", date: "May 22, 2026", posterPath: "m8lEffySgTuKxN3VsMd2gdgx1aw.jpg" },
  { title: "Backrooms", date: "May 29, 2026", posterPath: "vpkNMkbisv5cTaIfCzUduYzXnjb.jpg" },
  { title: "Masters of the Universe", date: "June 5, 2026", posterPath: "nm2ianYVp7OXElUZVeeAbNTqBLr.jpg" },
  { title: "Disclosure Day", date: "June 12, 2026", posterPath: "7RYO0KTXIJ0rS0LqnCQLxeNR3P3.jpg" },
  { title: "Supergirl", date: "June 26, 2026", posterPath: "niSvU02l2BONH9ivubV6K1a5QiK.jpg" },
  { title: "Evil Dead Burn", date: "July 24, 2026", posterPath: null },
  { title: "The End of Oak Street", date: "August 14, 2026", posterPath: "u9jha7bkttIrc5RO1TWeSn7QVyI.jpg" },
  { title: "Insidious: Out of the Further", date: "August 21, 2026", posterPath: "4tTrW9dXCByS5wt2pXVWb58zNjz.jpg" },
  { title: "Resident Evil", date: "September 18, 2026", posterPath: "3WkDXYtOwYHFFkpysAPxPgUMox0.jpg" },
  { title: "Godzilla Minus Zero", date: "November 6, 2026", posterPath: "zOeAduPBa1NZyX9TCcWXVpnHy3T.jpg" },
  { title: "Dune: Part Three", date: "December 18, 2026", posterPath: "b4wekkUaxExzOeGe7hKXzhnyXHt.jpg" },
];
---

<BaseLayout title="The Last Frame" description="Upcoming releases and posters.">
  <main class="stage">
    <div class="inner">
      <header class="brand">
        <h1 class="brand-heading">
          <a class="wordmark-link" href="/">
            <img
              class="logo-img"
              src="/the-last-frame-logo.svg"
              alt="The Last Frame"
              width="196"
              height="74"
              loading="eager"
              decoding="async"
            />
          </a>
        </h1>
      </header>

      <div class="rule" aria-hidden="true"></div>

      <p class="section-label">
        <span class="section-label-dot" aria-hidden="true"></span>
        Coming in 2026
      </p>

      <div class="poster-list">
        {
          UPCOMING.map((item) => (
            <article class="poster-block">
              <div class="frame-wrap">
                <div class="screen-bezel">
                  <div class="screen-glare" aria-hidden="true"></div>
                  {item.posterPath ? (
                    <div class="poster-surface">
                      <img
                        class="poster-img"
                        src={`${TMDB_IMG}/${item.posterPath}`}
                        alt={`Theatrical poster: ${item.title}`}
                        width={780}
                        height={1170}
                        loading="lazy"
                        decoding="async"
                        sizes="(max-width: 480px) 72vw, 280px"
                      />
                    </div>
                  ) : (
                    <div class="poster-surface poster-surface--empty">
                      <p class="poster-missing">No poster on TMDB yet</p>
                    </div>
                  )}
                </div>
              </div>
              <h2 class="poster-title">{item.title}</h2>
              <p class="poster-date">{item.date}</p>
            </article>
          ))
        }
      </div>

      <p class="attribution">
        Poster images from{" "}
        <a class="text-link" href="https://www.themoviedb.org/" target="_blank" rel="noopener noreferrer">
          The Movie Database (TMDB)
        </a>
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .stage {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 4vw, 1.5rem) clamp(2.5rem, 6vw, 4rem);
  }

  .inner {
    width: 100%;
    max-width: 42rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .brand-heading {
    margin: 0;
    line-height: 0;
  }

  .wordmark-link {
    display: inline-block;
    text-decoration: none;
    color: inherit;
    border: none;
    outline: none;
  }

  .wordmark-link:focus-visible {
    border-radius: 8px;
    box-shadow: 0 0 0 2px #08080a, 0 0 0 4px rgba(201, 162, 39, 0.65);
  }

  .logo-img {
    display: block;
    width: min(100%, 240px);
    max-width: 100%;
    height: auto;
    max-height: 92px;
  }

  .rule {
    width: min(10rem, 45vw);
    height: 1px;
    margin: clamp(1.5rem, 4vw, 2.25rem) 0;
    align-self: center;
    background: linear-gradient(90deg, transparent, rgba(201, 162, 39, 0.35), transparent);
  }

  .section-label {
    margin: 0 0 1.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #8a847a;
  }

  .section-label-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #c9a227;
    box-shadow: 0 0 8px rgba(201, 162, 39, 0.4);
    flex-shrink: 0;
  }

  .poster-list {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: clamp(2rem, 5vw, 2.75rem);
  }

  .poster-block {
    margin: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.65rem;
  }

  .frame-wrap {
    width: 100%;
    max-width: 280px;
    margin: 0 auto;
  }

  .screen-bezel {
    position: relative;
    border-radius: 6px;
    padding: 3px;
    background: linear-gradient(145deg, #2a2824 0%, #12100e 50%, #1a1814 100%);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.06) inset,
      0 24px 48px -12px rgba(0, 0, 0, 0.65);
  }

  .screen-glare {
    pointer-events: none;
    position: absolute;
    inset: 3px;
    border-radius: 4px;
    background: linear-gradient(
      125deg,
      rgba(255, 255, 255, 0.06) 0%,
      transparent 38%,
      transparent 100%
    );
    z-index: 1;
  }

  .poster-surface {
    position: relative;
    aspect-ratio: 2 / 3;
    width: 100%;
    border-radius: 4px;
    overflow: hidden;
    background: #0e0d0b;
    z-index: 0;
  }

  .poster-surface--empty {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background:
      linear-gradient(145deg, rgba(201, 162, 39, 0.06) 0%, transparent 45%),
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(40, 36, 30, 0.9), #0a0908);
  }

  .poster-missing {
    margin: 0;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.4;
    color: #6b6560;
    max-width: 12rem;
  }

  .poster-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .poster-title {
    margin: 0;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: clamp(1rem, 2.8vw, 1.125rem);
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #ede8df;
    line-height: 1.3;
    max-width: 28rem;
  }

  .poster-date {
    margin: 0;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: #8a847a;
  }

  .attribution {
    margin: 2.25rem 0 0;
    max-width: 22rem;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.45;
    color: #5c5752;
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
    }
  }
</style>
