---
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * Chronological 2026 US dates.
 * Posters: TMDB CDN (`w780`), except Evil Dead Burn — no poster on TMDB yet (Apr 2026).
 */
const TMDB_IMG = "https://image.tmdb.org/t/p/w780";

const UPCOMING = [
  { title: "Weekend at the End of the World", date: "April 20, 2026", posterPath: "lmkxctsfitUnLTbqLJHFjGJr5ru.jpg" },
  { title: "Mortal Kombat II", date: "May 8, 2026", posterPath: "io7wVbm9VKaanIcuAymCDy9dmjU.jpg" },
  { title: "The Mandalorian and Grogu", date: "May 22, 2026", posterPath: "m8lEffySgTuKxN3VsMd2gdgx1aw.jpg" },
  { title: "Backrooms", date: "May 29, 2026", posterPath: "vpkNMkbisv5cTaIfCzUduYzXnjb.jpg" },
  { title: "Masters of the Universe", date: "June 5, 2026", posterPath: "nm2ianYVp7OXElUZVeeAbNTqBLr.jpg" },
  { title: "Disclosure Day", date: "June 12, 2026", posterPath: "7RYO0KTXIJ0rS0LqnCQLxeNR3P3.jpg" },
  { title: "Supergirl", date: "June 26, 2026", posterPath: "niSvU02l2BONH9ivubV6K1a5QiK.jpg" },
  { title: "Evil Dead Burn", date: "July 24, 2026", posterPath: null },
  { title: "The End of Oak Street", date: "August 14, 2026", posterPath: "u9jha7bkttIrc5RO1TWeSn7QVyI.jpg" },
  { title: "Insidious: Out of the Further", date: "August 21, 2026", posterPath: "4tTrW9dXCByS5wt2pXVWb58zNjz.jpg" },
  { title: "Resident Evil", date: "September 18, 2026", posterPath: "3WkDXYtOwYHFFkpysAPxPgUMox0.jpg" },
  { title: "Godzilla Minus Zero", date: "November 6, 2026", posterPath: "zOeAduPBa1NZyX9TCcWXVpnHy3T.jpg" },
  { title: "Dune: Part Three", date: "December 18, 2026", posterPath: "b4wekkUaxExzOeGe7hKXzhnyXHt.jpg" },
];
---

<BaseLayout title="The Last Frame" description="Upcoming releases and posters.">
  <main class="stage">
    <div class="inner">
      <header class="brand">
        <h1 class="brand-heading">
          <a class="wordmark-link" href="/">
            <img
              class="logo-img"
              src="/the-last-frame-logo.svg"
              alt="The Last Frame"
              width="196"
              height="74"
              loading="eager"
              decoding="async"
            />
          </a>
        </h1>
      </header>

      <div class="rule" aria-hidden="true"></div>

      <p class="section-label">
        <span class="section-label-dot" aria-hidden="true"></span>
        Coming in 2026
      </p>

      <div class="poster-grid">
        {
          UPCOMING.map((item) => (
            <article class="poster-card">
              <div class="poster-card__media">
                {item.posterPath ? (
                  <img
                    class="poster-card__img"
                    src={`${TMDB_IMG}/${item.posterPath}`}
                    alt={`Theatrical poster: ${item.title}`}
                    width={780}
                    height={1170}
                    loading="lazy"
                    decoding="async"
                    sizes="(max-width: 520px) 42vw, (max-width: 900px) 28vw, 220px"
                  />
                ) : (
                  <div class="poster-card__placeholder">
                    <p class="poster-card__missing">No poster on TMDB yet</p>
                  </div>
                )}
              </div>
              <div class="poster-card__body">
                <h2 class="poster-card__title">{item.title}</h2>
                <p class="poster-card__date">{item.date}</p>
              </div>
            </article>
          ))
        }
      </div>

      <p class="attribution">
        Poster images from{" "}
        <a class="text-link" href="https://www.themoviedb.org/" target="_blank" rel="noopener noreferrer">
          The Movie Database (TMDB)
        </a>
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .stage {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 4vw, 1.5rem) clamp(2.5rem, 6vw, 4rem);
  }

  .inner {
    width: 100%;
    max-width: 72rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .brand-heading {
    margin: 0;
    line-height: 0;
  }

  .wordmark-link {
    display: inline-block;
    text-decoration: none;
    color: inherit;
    border: none;
    outline: none;
  }

  .wordmark-link:focus-visible {
    border-radius: 8px;
    box-shadow: 0 0 0 2px #08080a, 0 0 0 4px rgba(201, 162, 39, 0.65);
  }

  .logo-img {
    display: block;
    width: min(100%, 240px);
    max-width: 100%;
    height: auto;
    max-height: 92px;
  }

  .rule {
    width: min(10rem, 45vw);
    height: 1px;
    margin: clamp(1.5rem, 4vw, 2.25rem) 0;
    align-self: center;
    background: linear-gradient(90deg, transparent, rgba(201, 162, 39, 0.35), transparent);
  }

  .section-label {
    margin: 0 0 1.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #8a847a;
  }

  .section-label-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #c9a227;
    box-shadow: 0 0 8px rgba(201, 162, 39, 0.4);
    flex-shrink: 0;
  }

  .poster-grid {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.25rem;
    align-items: stretch;
  }

  @media (min-width: 640px) {
    .poster-grid {
      gap: 1.5rem;
    }
  }

  .poster-card {
    margin: 0;
    display: flex;
    flex-direction: column;
    border-radius: 10px;
    overflow: hidden;
    text-align: left;
    background: linear-gradient(165deg, #181614 0%, #0f0e0c 55%, #0c0b09 100%);
    border: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.35) inset,
      0 16px 40px -14px rgba(0, 0, 0, 0.75);
  }

  .poster-card__media {
    position: relative;
    aspect-ratio: 2 / 3;
    width: 100%;
    background: #0a0908;
    overflow: hidden;
  }

  .poster-card__media::after {
    content: "";
    pointer-events: none;
    position: absolute;
    inset: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    background: linear-gradient(
      165deg,
      rgba(255, 255, 255, 0.04) 0%,
      transparent 35%,
      transparent 100%
    );
  }

  .poster-card__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .poster-card__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    padding: 1rem;
    background:
      linear-gradient(145deg, rgba(201, 162, 39, 0.07) 0%, transparent 50%),
      radial-gradient(ellipse 90% 70% at 50% 0%, rgba(35, 31, 26, 0.95), #0a0908);
  }

  .poster-card__missing {
    margin: 0;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.4;
    color: #6b6560;
    text-align: center;
  }

  .poster-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.85rem 1rem 1.15rem;
  }

  .poster-card__title {
    margin: 0;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.015em;
    color: #ede8df;
    line-height: 1.35;
  }

  .poster-card__date {
    margin: 0;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a847a;
  }

  .attribution {
    margin: 2.25rem 0 0;
    max-width: 22rem;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.45;
    color: #5c5752;
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
    }
  }
</style>
