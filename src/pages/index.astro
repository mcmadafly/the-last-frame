---
import BaseLayout from "../layouts/BaseLayout.astro";

/** Official Sony Pictures trailer — swap `id` / metadata when you rotate the feature. */
const FEATURED = {
  title: "28 Years Later",
  tagline: "The infection evolved. So did the world.",
  youtubeId: "UdRkVQVoM1U",
  channelUrl: "https://www.youtube.com/@SonyPictures",
  context: "Danny Boyle and Alex Garland return to the world of 28 Days Later — in theaters June 20.",
} as const;
---

<BaseLayout
  title="The Last Frame — Horror & sci-fi trailers, curated"
  description="Community-driven archive of horror and sci-fi: official trailer embeds, reviews, and ranked lists."
>
  <div class="page">
    <header class="header">
      <div class="header-rule" aria-hidden="true"></div>
      <div class="header-inner">
        <a class="brand" href="/" aria-label="The Last Frame home">
          <svg class="logo" viewBox="0 0 40 40" role="img" aria-hidden="true">
            <defs>
              <linearGradient id="frame" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#7dd3fc"></stop>
                <stop offset="100%" stop-color="#38bdf8"></stop>
              </linearGradient>
            </defs>
            <rect x="2" y="2" width="36" height="36" rx="9" fill="#0b1220" stroke="url(#frame)" stroke-width="1.2"></rect>
            <rect x="8" y="9" width="24" height="16" rx="1.5" fill="#0f172a" stroke="#1e293b" stroke-width="0.6"></rect>
            <path d="M16 15l8 5-8 5V15z" fill="url(#frame)"></path>
          </svg>
          <div class="wordmark">
            <span class="name">The Last Frame</span>
            <span class="sub">Horror · Sci-fi · Archive</span>
          </div>
        </a>
        <p class="header-tag">Official embeds · Editorial · Lists</p>
      </div>
    </header>

    <main class="main">
      <section class="hero">
        <p class="eyebrow"><span class="eyebrow-dot" aria-hidden="true"></span> Now screening</p>
        <div class="hero-grid">
          <div class="hero-copy">
            <h1 class="headline">Trailers with context—<span class="headline-muted">not just algorithms.</span></h1>
            <p class="lede">
              A community archive built on official channels: embeds you can trust, reviews with teeth, and ranked lists
              shaped by people who actually show up for the genre. Pick a fight about what earns the <em>last frame</em>.
            </p>
          </div>
          <aside class="hero-meta" aria-label="Site focus">
            <ul class="meta-list">
              <li><span class="meta-k">Lens</span> Horror &amp; sci-fi</li>
              <li><span class="meta-k">Source</span> YouTube / Vimeo embeds</li>
              <li><span class="meta-k">Promise</span> Link out to official uploads</li>
            </ul>
          </aside>
        </div>
      </section>

      <section class="feature" aria-labelledby="feature-heading">
        <div class="feature-head">
          <div class="feature-label">
            <h2 id="feature-heading" class="feature-title">Featured trailer</h2>
            <p class="feature-sub">Rotating pick — always from an official distributor channel.</p>
          </div>
          <span class="pill">Coming soon</span>
        </div>

        <article class="card">
          <div class="filmstrip" aria-hidden="true"></div>
          <div class="card-body">
            <div class="card-top">
              <h3 class="film-title">{FEATURED.title}</h3>
              <p class="film-tagline">{FEATURED.tagline}</p>
              <p class="film-context">{FEATURED.context}</p>
            </div>
            <div class="embed-wrap">
              <iframe
                title={`${FEATURED.title} — official trailer (YouTube)`}
                src={`https://www.youtube-nocookie.com/embed/${FEATURED.youtubeId}?rel=0&modestbranding=1`}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
            <p class="attribution">
              Trailer via
              <a href={FEATURED.channelUrl} target="_blank" rel="noopener noreferrer">Sony Pictures on YouTube</a>.
              Prefer watching on the uploader’s official channel when you can.
            </p>
          </div>
        </article>
      </section>
    </main>

    <footer class="footer">
      <span class="footer-brand">The Last Frame</span>
      <span class="dot" aria-hidden="true">·</span>
      <span>Built for late-night double features and cosmic dread.</span>
    </footer>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 58rem;
    margin: 0 auto;
    padding: clamp(1.25rem, 4vw, 2.25rem);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .header {
    margin-bottom: 2.75rem;
  }

  .header-rule {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(148, 163, 184, 0.35), transparent);
    margin-bottom: 1.25rem;
  }

  .header-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    text-decoration: none;
    color: inherit;
  }

  .logo {
    width: 2.75rem;
    height: 2.75rem;
    flex-shrink: 0;
    filter: drop-shadow(0 0 20px rgba(56, 189, 248, 0.2));
  }

  .wordmark {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .name {
    font-family: "Syne", system-ui, sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
    color: #f8fafc;
    line-height: 1.1;
  }

  .sub {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(148, 163, 184, 0.85);
  }

  .header-tag {
    margin: 0;
    font-size: 0.8rem;
    color: rgba(148, 163, 184, 0.75);
    letter-spacing: 0.02em;
  }

  .main {
    flex: 1;
  }

  .hero {
    margin-bottom: 3rem;
  }

  .eyebrow {
    margin: 0 0 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #38bdf8;
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #38bdf8;
    box-shadow: 0 0 12px rgba(56, 189, 248, 0.7);
  }

  .hero-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 720px) {
    .hero-grid {
      grid-template-columns: 1fr minmax(12rem, 16rem);
      align-items: start;
    }
  }

  .headline {
    margin: 0 0 1rem;
    font-family: "Syne", system-ui, sans-serif;
    font-weight: 600;
    font-size: clamp(1.85rem, 4.5vw, 2.65rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: #f1f5f9;
  }

  .headline-muted {
    color: #64748b;
    font-weight: 600;
  }

  .lede {
    margin: 0;
    max-width: 40rem;
    font-size: 1.02rem;
    color: rgba(203, 213, 225, 0.92);
  }

  .lede em {
    font-style: italic;
    color: #e2e8f0;
  }

  .hero-meta {
    border-left: 3px solid rgba(56, 189, 248, 0.45);
    padding-left: 1.1rem;
    background: linear-gradient(90deg, rgba(15, 23, 42, 0.5), transparent);
    padding-top: 0.35rem;
    padding-bottom: 0.35rem;
    border-radius: 0 4px 4px 0;
  }

  .meta-list {
    margin: 0;
    padding: 0;
    list-style: none;
    font-size: 0.85rem;
    color: rgba(148, 163, 184, 0.95);
    line-height: 1.7;
  }

  .meta-k {
    display: block;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.58rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(125, 211, 252, 0.85);
    margin-bottom: 0.1rem;
  }

  .feature-head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.15rem;
  }

  .feature-label {
    max-width: 36rem;
  }

  .feature-title {
    margin: 0 0 0.25rem;
    font-family: "Syne", system-ui, sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #f8fafc;
  }

  .feature-sub {
    margin: 0;
    font-size: 0.85rem;
    color: rgba(148, 163, 184, 0.85);
  }

  .pill {
    display: inline-block;
    padding: 0.28rem 0.75rem;
    border-radius: 2px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #0f172a;
    background: linear-gradient(135deg, #a78bfa, #7dd3fc);
    white-space: nowrap;
  }

  .card {
    position: relative;
    border-radius: 4px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(15, 23, 42, 0.45);
    box-shadow:
      0 0 0 1px rgba(15, 23, 42, 0.6) inset,
      0 28px 56px rgba(0, 0, 0, 0.45);
    overflow: hidden;
  }

  .filmstrip {
    height: 10px;
    background: repeating-linear-gradient(
      90deg,
      #0f172a 0px,
      #0f172a 10px,
      #1e293b 10px,
      #1e293b 14px
    );
    opacity: 0.85;
  }

  .card-body {
    padding: 0;
  }

  .card-top {
    padding: 1.35rem 1.35rem 0;
  }

  .film-title {
    margin: 0 0 0.35rem;
    font-family: "Syne", system-ui, sans-serif;
    font-size: 1.45rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #f8fafc;
  }

  .film-tagline {
    margin: 0 0 0.65rem;
    font-size: 1rem;
    font-style: italic;
    color: rgba(226, 232, 240, 0.9);
  }

  .film-context {
    margin: 0;
    font-size: 0.88rem;
    color: rgba(148, 163, 184, 0.95);
  }

  .embed-wrap {
    position: relative;
    margin-top: 1.25rem;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #020617;
    border-top: 1px solid rgba(30, 41, 59, 0.9);
    border-bottom: 1px solid rgba(30, 41, 59, 0.9);
  }

  .embed-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .attribution {
    margin: 0;
    padding: 1rem 1.35rem 1.35rem;
    font-size: 0.78rem;
    color: rgba(148, 163, 184, 0.75);
    line-height: 1.55;
  }

  .footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(51, 65, 85, 0.45);
    font-size: 0.78rem;
    color: rgba(100, 116, 139, 0.95);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }

  .footer-brand {
    font-family: "Syne", system-ui, sans-serif;
    font-weight: 600;
    color: rgba(148, 163, 184, 0.95);
  }

  .dot {
    opacity: 0.45;
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
    }
  }
</style>
