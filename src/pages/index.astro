---
import BaseLayout from "../layouts/BaseLayout.astro";

const FEATURED = {
  youtubeId: "UdRkVQVoM1U",
  channelUrl: "https://www.youtube.com/@SonyPictures",
} as const;
---

<BaseLayout title="The Last Frame" description="The best of sci-fi and horror — upcoming releases and trailers.">
  <main class="stage">
    <div class="inner">
      <header class="brand">
        <a class="brand-link" href="/" aria-label="The Last Frame home">
          <svg class="brand-icon" viewBox="0 0 48 48" aria-hidden="true">
            <defs>
              <linearGradient id="gold" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#e8d5a3"></stop>
                <stop offset="100%" stop-color="#9a7b2c"></stop>
              </linearGradient>
            </defs>
            <rect x="1" y="1" width="46" height="46" rx="10" fill="#0c0c0f" stroke="url(#gold)" stroke-width="1"></rect>
            <rect x="11" y="13" width="26" height="18" rx="2" fill="#060608" stroke="#2a2824" stroke-width="0.8"></rect>
            <path d="M20 18l10 6.5-10 6.5V18z" fill="url(#gold)"></path>
          </svg>
          <div class="brand-text">
            <span class="brand-name">The Last Frame</span>
            <p class="tagline">the best of scifi and horror</p>
          </div>
        </a>
      </header>

      <div class="rule" aria-hidden="true"></div>

      <p class="upcoming">
        <span class="upcoming-dot" aria-hidden="true"></span>
        Upcoming release
      </p>

      <div class="screen">
        <div class="screen-bezel">
          <div class="screen-glare" aria-hidden="true"></div>
          <div class="screen-video">
            <iframe
              title="Featured trailer on YouTube"
              src={`https://www.youtube-nocookie.com/embed/${FEATURED.youtubeId}?rel=0&modestbranding=1`}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </div>

      <p class="credit">
        Official embed ·
        <a href={FEATURED.channelUrl} target="_blank" rel="noopener noreferrer">Sony Pictures on YouTube</a>
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .stage {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1.75rem, 5vw, 3rem) clamp(1.25rem, 4vw, 2rem);
  }

  .inner {
    width: 100%;
    max-width: 44rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .brand {
    width: 100%;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: clamp(0.85rem, 3vw, 1.15rem);
    text-decoration: none;
    color: inherit;
    text-align: left;
  }

  @media (max-width: 420px) {
    .brand-link {
      flex-direction: column;
      text-align: center;
    }
  }

  .brand-icon {
    width: clamp(3rem, 8vw, 3.5rem);
    height: clamp(3rem, 8vw, 3.5rem);
    flex-shrink: 0;
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.5));
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }

  .brand-name {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-weight: 700;
    font-size: clamp(1.85rem, 5vw, 2.35rem);
    letter-spacing: 0.02em;
    line-height: 1.05;
    color: #faf8f4;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }

  .tagline {
    margin: 0;
    font-family: "Libre Caslon Text", Georgia, serif;
    font-size: clamp(0.98rem, 2.4vw, 1.125rem);
    font-style: italic;
    font-weight: 400;
    color: #a39e96;
    letter-spacing: 0.01em;
    line-height: 1.35;
  }

  .rule {
    width: min(12rem, 50vw);
    height: 1px;
    margin: clamp(2rem, 5vw, 2.75rem) 0;
    background: linear-gradient(90deg, transparent, rgba(201, 162, 39, 0.35), transparent);
  }

  .upcoming {
    margin: 0 0 1.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: #7a756c;
  }

  .upcoming-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #c9a227;
    box-shadow: 0 0 10px rgba(201, 162, 39, 0.45);
    flex-shrink: 0;
  }

  .screen {
    width: 100%;
  }

  .screen-bezel {
    position: relative;
    border-radius: 6px;
    padding: 3px;
    background: linear-gradient(145deg, #2a2824 0%, #12100e 50%, #1a1814 100%);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.06) inset,
      0 32px 64px -16px rgba(0, 0, 0, 0.75),
      0 0 80px -20px rgba(201, 162, 39, 0.08);
  }

  .screen-glare {
    pointer-events: none;
    position: absolute;
    inset: 3px;
    border-radius: 4px;
    background: linear-gradient(
      125deg,
      rgba(255, 255, 255, 0.06) 0%,
      transparent 42%,
      transparent 100%
    );
    z-index: 1;
  }

  .screen-video {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 4px;
    overflow: hidden;
    background: #000;
    z-index: 0;
  }

  .screen-video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .credit {
    margin: 1.25rem 0 0;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #5c5852;
  }

  .credit a {
    font-weight: 600;
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
    }
  }
</style>
