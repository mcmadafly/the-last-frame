---

<BaseLayout title="The Last Frame" description="Upcoming releases and posters.">
  <main class="stage">
    <div class="inner">
      <header class="site-header">
        <h1 class="site-header__brand">
          <a class="site-header__logo-link" href="/">
            <img
              class="site-header__logo"
              src="/the-last-frame-logo.svg"
              alt="The Last Frame"
              width="196"
              height="74"
              loading="eager"
              decoding="async"
            />
          </a>
        </h1>
        <nav class="site-header__nav" aria-label="Site">
          <a class="site-header__nav-link" href="#grid">Browse</a>
          <a class="site-header__nav-link" href="#">About</a>
        </nav>
      </header>

      <div class="rule" aria-hidden="true"></div>

      <div class="toolbar">
        <div class="toolbar__segment" role="group" aria-label="Release filter">
          <button type="button" class="seg-btn seg-btn--active" data-view="coming" aria-pressed="true">
            Coming in 2026
          </button>
          <button type="button" class="seg-btn" data-view="released" aria-pressed="false">
            Released
          </button>
        </div>
        <div class="toolbar__filters" role="group" aria-label="Genre filter">
          <button type="button" class="filter-btn filter-btn--active" data-filter="all" aria-pressed="true">
            All
          </button>
          <button type="button" class="filter-btn" data-filter="horror" aria-pressed="false">
            Horror
          </button>
          <button type="button" class="filter-btn" data-filter="sci-fi" aria-pressed="false">
            Sci-Fi
          </button>
        </div>
      </div>

      <div class="poster-grid" id="grid" data-movie-grid>
        {
          FILMS.map((item) => (
            <article
              class="poster-card"
              data-poster-card
              data-status={item.status}
              data-genres={item.genres.join(" ")}
              hidden={item.status === "released"}
            >
              <div class="poster-card__media">
                {item.posterPath ? (
                  <img
                    class="poster-card__img"
                    src={`${TMDB_IMG}/${item.posterPath}`}
                    alt={`Theatrical poster: ${item.title}`}
                    width={780}
                    height={1170}
                    loading="lazy"
                    decoding="async"
                    sizes="(max-width: 520px) 42vw, (max-width: 900px) 28vw, 220px"
                  />
                ) : (
                  <div class="poster-card__placeholder">
                    <p class="poster-card__missing">No poster on TMDB yet</p>
                  </div>
                )}
              </div>
              <div class="poster-card__body">
                <h2 class="poster-card__title">{item.title}</h2>
                <p class="poster-card__date">{item.date}</p>
              </div>
            </article>
          ))
        }
      </div>

      <p class="attribution">
        Poster art via{" "}
        <a class="text-link" href="https://www.themoviedb.org/" target="_blank" rel="noopener noreferrer">
          TMDB
        </a>
        . Additional 2026 titles sourced from Letterboxd lists such as{" "}
        <a
          class="text-link"
          href="https://letterboxd.com/tracedthurman/list/2026-horror-films/"
          target="_blank"
          rel="noopener noreferrer"
        >
          2026 Horror Films
        </a>
        .
      </p>
    </div>
  </main>
</BaseLayout>

<script>
  (function () {
    const cards = document.querySelectorAll("[data-poster-card]");
    const segButtons = document.querySelectorAll("[data-view]");
    const filterButtons = document.querySelectorAll("[data-filter]");

    let view = "coming";
    /** @type {"all" | "horror" | "sci-fi"} */
    let filter = "all";

    function apply() {
      cards.forEach((el) => {
        const st = el.getAttribute("data-status");
        const genres = (el.getAttribute("data-genres") || "").split(/\s+/).filter(Boolean);
        let show = st === view;
        if (show && filter !== "all") {
          show = genres.includes(filter);
        }
        el.hidden = !show;
      });
    }

    /** @param {"coming" | "released"} v */
    function setSegActive(v) {
      view = v;
      segButtons.forEach((btn) => {
        const on = btn.getAttribute("data-view") === v;
        btn.classList.toggle("seg-btn--active", on);
        btn.setAttribute("aria-pressed", on ? "true" : "false");
      });
      apply();
    }

    /** @param {"all" | "horror" | "sci-fi"} f */
    function setFilterActive(f) {
      filter = f;
      filterButtons.forEach((btn) => {
        const on = btn.getAttribute("data-filter") === f;
        btn.classList.toggle("filter-btn--active", on);
        btn.setAttribute("aria-pressed", on ? "true" : "false");
      });
      apply();
    }

    segButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const v = btn.getAttribute("data-view");
        if (v === "coming" || v === "released") setSegActive(v);
      });
    });

    filterButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const f = btn.getAttribute("data-filter");
        if (f === "all" || f === "horror" || f === "sci-fi") setFilterActive(f);
      });
    });
  })();
</script>

<style>
  .stage {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: clamp(1.25rem, 3vw, 2rem) clamp(1rem, 4vw, 1.5rem) clamp(2.5rem, 6vw, 4rem);
  }

  .inner {
    width: 100%;
    max-width: 72rem;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    text-align: center;
  }

  .site-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
  }

  .site-header__brand {
    margin: 0;
    line-height: 0;
  }

  .site-header__logo-link {
    display: inline-block;
    text-decoration: none;
    border: none;
    outline: none;
  }

  .site-header__logo-link:focus-visible {
    border-radius: 8px;
    box-shadow: 0 0 0 2px #08080a, 0 0 0 4px rgba(201, 162, 39, 0.65);
  }

  .site-header__logo {
    display: block;
    width: min(100%, 240px);
    max-width: 100%;
    height: auto;
    max-height: 92px;
  }

  .site-header__nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem 1.25rem;
  }

  .site-header__nav-link {
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #9a948a;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .site-header__nav-link:hover {
    color: #d4cdc0;
    border-bottom-color: rgba(201, 162, 39, 0.35);
  }

  @media (min-width: 900px) {
    .site-header {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      gap: 1.5rem;
    }

    .site-header__nav {
      justify-content: flex-end;
    }
  }

  .rule {
    width: min(10rem, 45vw);
    height: 1px;
    margin: clamp(1.25rem, 3vw, 1.75rem) auto;
    background: linear-gradient(90deg, transparent, rgba(201, 162, 39, 0.35), transparent);
  }

  .toolbar {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 1rem;
    margin-bottom: 1.5rem;
    width: 100%;
  }

  .toolbar__segment {
    display: inline-flex;
    align-self: center;
    padding: 3px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .seg-btn {
    appearance: none;
    margin: 0;
    padding: 0.45rem 1rem;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #8a847a;
    background: transparent;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .seg-btn:hover {
    color: #c9c2b8;
  }

  .seg-btn--active {
    color: #f4f1ec;
    background: linear-gradient(180deg, rgba(201, 162, 39, 0.22) 0%, rgba(201, 162, 39, 0.08) 100%);
    box-shadow: 0 0 0 1px rgba(201, 162, 39, 0.25);
  }

  .seg-btn:focus-visible,
  .filter-btn:focus-visible {
    outline: 2px solid rgba(201, 162, 39, 0.65);
    outline-offset: 2px;
  }

  .toolbar__filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .filter-btn {
    appearance: none;
    margin: 0;
    padding: 0.35rem 0.85rem;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #8a847a;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    cursor: pointer;
    transition:
      color 0.15s ease,
      background 0.15s ease,
      border-color 0.15s ease;
  }

  .filter-btn:hover {
    color: #c9c2b8;
    border-color: rgba(255, 255, 255, 0.16);
  }

  .filter-btn--active {
    color: #ede8df;
    background: rgba(201, 162, 39, 0.12);
    border-color: rgba(201, 162, 39, 0.35);
  }

  @media (min-width: 900px) {
    .toolbar {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 1rem 1.5rem;
    }

    .toolbar__segment {
      align-self: auto;
    }

    .toolbar__filters {
      justify-content: flex-end;
      margin-left: auto;
    }
  }

  .poster-grid {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.25rem;
    align-items: stretch;
  }

  @media (min-width: 640px) {
    .poster-grid {
      gap: 1.5rem;
    }
  }

  .poster-card {
    margin: 0;
    display: flex;
    flex-direction: column;
    border-radius: 10px;
    overflow: hidden;
    text-align: left;
    background: linear-gradient(165deg, #181614 0%, #0f0e0c 55%, #0c0b09 100%);
    border: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.35) inset,
      0 16px 40px -14px rgba(0, 0, 0, 0.75);
  }

  .poster-card[hidden] {
    display: none;
  }

  .poster-card__media {
    position: relative;
    aspect-ratio: 2 / 3;
    width: 100%;
    background: #0a0908;
    overflow: hidden;
  }

  .poster-card__media::after {
    content: "";
    pointer-events: none;
    position: absolute;
    inset: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    background: linear-gradient(
      165deg,
      rgba(255, 255, 255, 0.04) 0%,
      transparent 35%,
      transparent 100%
    );
  }

  .poster-card__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .poster-card__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    padding: 1rem;
    background:
      linear-gradient(145deg, rgba(201, 162, 39, 0.07) 0%, transparent 50%),
      radial-gradient(ellipse 90% 70% at 50% 0%, rgba(35, 31, 26, 0.95), #0a0908);
  }

  .poster-card__missing {
    margin: 0;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.4;
    color: #6b6560;
    text-align: center;
  }

  .poster-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.85rem 1rem 1.15rem;
  }

  .poster-card__title {
    margin: 0;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.015em;
    color: #ede8df;
    line-height: 1.35;
  }

  .poster-card__date {
    margin: 0;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a847a;
  }

  .attribution {
    margin: 2.25rem auto 0;
    max-width: 28rem;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.45;
    color: #5c5752;
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
    }
  }
</style>
