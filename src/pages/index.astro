---
import BaseLayout from "../layouts/BaseLayout.astro";

/** Chronological 2026 US dates; `youtubeId` null = no official trailer on YouTube yet (Apr 2026). */
const UPCOMING = [
  { title: "Weekend at the End of the World", date: "April 20, 2026", youtubeId: "YYeeDYYEbeo" },
  { title: "Mortal Kombat II", date: "May 8, 2026", youtubeId: "z6fz_ewTKTs" },
  { title: "The Mandalorian and Grogu", date: "May 22, 2026", youtubeId: "IHWlvwu8t1w" },
  { title: "Backrooms", date: "May 29, 2026", youtubeId: "wek9dIw2uVM" },
  { title: "Masters of the Universe", date: "June 5, 2026", youtubeId: "X21JsHLHnY8" },
  { title: "Disclosure Day", date: "June 12, 2026", youtubeId: "89uCBeGBIJQ" },
  { title: "Supergirl", date: "June 26, 2026", youtubeId: "s1-pfiVMKAs" },
  { title: "Evil Dead Burn", date: "July 24, 2026", youtubeId: null },
  { title: "The End of Oak Street", date: "August 14, 2026", youtubeId: "mzHx2Iz582s" },
  { title: "Insidious: Out of the Further", date: "August 21, 2026", youtubeId: "jxU8FU3o75A" },
  { title: "Resident Evil", date: "September 18, 2026", youtubeId: null },
  { title: "Godzilla Minus Zero", date: "November 6, 2026", youtubeId: "n-NDYWPXpKg" },
  { title: "Dune: Part Three", date: "December 18, 2026", youtubeId: "w0KyEhJ-0S0" },
];
---

<BaseLayout title="The Last Frame" description="Trailers and upcoming releases.">
  <main class="stage">
    <div class="inner">
      <header class="brand">
        <h1 class="brand-heading">
          <a class="wordmark-link" href="/">
            <img
              class="logo-img"
              src="/the-last-frame-logo.svg"
              alt="The Last Frame"
              width="196"
              height="74"
              loading="eager"
              decoding="async"
            />
          </a>
        </h1>
      </header>

      <div class="rule" aria-hidden="true"></div>

      <p class="section-label">
        <span class="section-label-dot" aria-hidden="true"></span>
        Coming in 2026
      </p>

      <div class="trailer-list">
        {
          UPCOMING.map((item) => (
            <article class="trailer-block">
              <div class="screen">
                <div class="screen-bezel">
                  <div class="screen-glare" aria-hidden="true"></div>
                  {item.youtubeId ? (
                    <div class="screen-video">
                      <iframe
                        title={`Trailer: ${item.title}`}
                        src={`https://www.youtube-nocookie.com/embed/${item.youtubeId}?rel=0&modestbranding=1`}
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        referrerpolicy="strict-origin-when-cross-origin"
                        allowfullscreen
                        loading="lazy"
                      ></iframe>
                    </div>
                  ) : (
                    <div class="screen-video screen-video--placeholder">
                      <p class="placeholder-text">
                        Official trailer not on YouTube yet — check back after the studio drop.
                      </p>
                    </div>
                  )}
                </div>
              </div>
              <h2 class="trailer-title">{item.title}</h2>
              <p class="trailer-date">{item.date}</p>
            </article>
          ))
        }
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .stage {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 4vw, 1.5rem) clamp(2.5rem, 6vw, 4rem);
  }

  .inner {
    width: 100%;
    max-width: 42rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .brand-heading {
    margin: 0;
    line-height: 0;
  }

  .wordmark-link {
    display: inline-block;
    text-decoration: none;
    color: inherit;
    border: none;
    outline: none;
  }

  .wordmark-link:focus-visible {
    border-radius: 8px;
    box-shadow: 0 0 0 2px #08080a, 0 0 0 4px rgba(201, 162, 39, 0.65);
  }

  .logo-img {
    display: block;
    width: min(100%, 240px);
    max-width: 100%;
    height: auto;
    max-height: 92px;
  }

  .rule {
    width: min(10rem, 45vw);
    height: 1px;
    margin: clamp(1.5rem, 4vw, 2.25rem) 0;
    align-self: center;
    background: linear-gradient(90deg, transparent, rgba(201, 162, 39, 0.35), transparent);
  }

  .section-label {
    margin: 0 0 1.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #8a847a;
  }

  .section-label-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #c9a227;
    box-shadow: 0 0 8px rgba(201, 162, 39, 0.4);
    flex-shrink: 0;
  }

  .trailer-list {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: clamp(2rem, 5vw, 2.75rem);
  }

  .trailer-block {
    margin: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.65rem;
  }

  .screen {
    width: 100%;
    max-width: 100%;
  }

  .screen-bezel {
    position: relative;
    border-radius: 6px;
    padding: 3px;
    background: linear-gradient(145deg, #2a2824 0%, #12100e 50%, #1a1814 100%);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.06) inset,
      0 24px 48px -12px rgba(0, 0, 0, 0.65);
  }

  .screen-glare {
    pointer-events: none;
    position: absolute;
    inset: 3px;
    border-radius: 4px;
    background: linear-gradient(
      125deg,
      rgba(255, 255, 255, 0.05) 0%,
      transparent 40%,
      transparent 100%
    );
    z-index: 1;
  }

  .screen-video {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 4px;
    overflow: hidden;
    background: #000;
    z-index: 0;
  }

  .screen-video--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem;
    background: linear-gradient(180deg, #141210 0%, #0a0908 100%);
  }

  .placeholder-text {
    margin: 0;
    max-width: 18rem;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.45;
    color: #7a746c;
  }

  .screen-video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .trailer-title {
    margin: 0;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: clamp(1rem, 2.8vw, 1.125rem);
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #ede8df;
    line-height: 1.3;
    max-width: 28rem;
  }

  .trailer-date {
    margin: 0;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: #8a847a;
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
    }
  }
</style>
