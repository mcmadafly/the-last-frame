---
import BaseLayout from "../layouts/BaseLayout.astro";

const FEATURED = {
  youtubeId: "UdRkVQVoM1U",
  channelUrl: "https://www.youtube.com/@SonyPictures",
} as const;
---

<BaseLayout title="The Last Frame" description="The best of sci-fi and horror — upcoming releases and trailers.">
  <main class="stage">
    <div class="inner">
      <header class="brand">
        <a class="logo-link" href="/" aria-label="The Last Frame — home">
          <!-- width/height attributes prevent SVG from expanding to fill the viewport in some browsers -->
          <svg
            class="logo-svg"
            width="48"
            height="48"
            viewBox="0 0 48 48"
            role="img"
            aria-hidden="true"
          >
            <defs>
              <linearGradient id="logoGold" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#e8d5a3"></stop>
                <stop offset="100%" stop-color="#9a7b2c"></stop>
              </linearGradient>
            </defs>
            <rect x="1" y="1" width="46" height="46" rx="10" fill="#0c0c0f" stroke="url(#logoGold)" stroke-width="1"></rect>
            <rect x="11" y="13" width="26" height="18" rx="2" fill="#060608" stroke="#2a2824" stroke-width="0.8"></rect>
            <path d="M20 18l10 6.5-10 6.5V18z" fill="url(#logoGold)"></path>
          </svg>
        </a>

        <div class="brand-copy">
          <h1 class="brand-name">The Last Frame</h1>
          <p class="tagline">the best of scifi and horror</p>
        </div>
      </header>

      <div class="rule" aria-hidden="true"></div>

      <p class="upcoming">
        <span class="upcoming-dot" aria-hidden="true"></span>
        Upcoming release
      </p>

      <div class="screen">
        <div class="screen-bezel">
          <div class="screen-glare" aria-hidden="true"></div>
          <div class="screen-video">
            <iframe
              title="Featured trailer on YouTube"
              src={`https://www.youtube-nocookie.com/embed/${FEATURED.youtubeId}?rel=0&modestbranding=1`}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </div>

      <p class="credit">
        Official embed ·
        <a class="text-link" href={FEATURED.channelUrl} target="_blank" rel="noopener noreferrer">Sony Pictures on YouTube</a>
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .stage {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 4vw, 1.5rem) clamp(2rem, 5vw, 3rem);
  }

  .inner {
    width: 100%;
    max-width: 40rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
  }

  .logo-link {
    display: block;
    line-height: 0;
    text-decoration: none;
    border: none;
    outline: none;
  }

  .logo-link:focus-visible {
    border-radius: 12px;
    box-shadow: 0 0 0 2px #08080a, 0 0 0 4px #c9a227;
  }

  /* Hard cap: SVG must never scale past 48px (fixes giant-logo bug) */
  .logo-svg {
    display: block;
    width: 48px !important;
    height: 48px !important;
    max-width: 48px !important;
    max-height: 48px !important;
    flex-shrink: 0;
    filter: drop-shadow(0 6px 18px rgba(0, 0, 0, 0.45));
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    align-items: center;
  }

  .brand-name {
    margin: 0;
    font-family: "Cormorant Garamond", Georgia, serif;
    font-weight: 700;
    font-size: clamp(1.65rem, 4.5vw, 2.1rem);
    letter-spacing: 0.02em;
    line-height: 1.1;
    color: #faf8f4;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }

  .tagline {
    margin: 0;
    font-family: "Libre Caslon Text", Georgia, serif;
    font-size: clamp(0.95rem, 2.2vw, 1.05rem);
    font-style: italic;
    font-weight: 400;
    color: #a39e96;
    letter-spacing: 0.01em;
    line-height: 1.4;
  }

  .rule {
    width: min(10rem, 45vw);
    height: 1px;
    margin: clamp(1.5rem, 4vw, 2.25rem) 0;
    background: linear-gradient(90deg, transparent, rgba(201, 162, 39, 0.35), transparent);
  }

  .upcoming {
    margin: 0 0 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #8a847a;
  }

  .upcoming-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #c9a227;
    box-shadow: 0 0 8px rgba(201, 162, 39, 0.4);
    flex-shrink: 0;
  }

  .screen {
    width: 100%;
    max-width: 100%;
  }

  .screen-bezel {
    position: relative;
    border-radius: 6px;
    padding: 3px;
    background: linear-gradient(145deg, #2a2824 0%, #12100e 50%, #1a1814 100%);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.06) inset,
      0 24px 48px -12px rgba(0, 0, 0, 0.65);
  }

  .screen-glare {
    pointer-events: none;
    position: absolute;
    inset: 3px;
    border-radius: 4px;
    background: linear-gradient(
      125deg,
      rgba(255, 255, 255, 0.05) 0%,
      transparent 40%,
      transparent 100%
    );
    z-index: 1;
  }

  .screen-video {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 4px;
    overflow: hidden;
    background: #000;
    z-index: 0;
  }

  .screen-video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .credit {
    margin: 1.1rem 0 0;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: #6b6560;
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      transition: none !important;
    }
  }
</style>
