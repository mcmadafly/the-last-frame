---
import BaseLayout from "../layouts/BaseLayout.astro";

/** Official Sony Pictures trailer — swap `id` / metadata when you rotate the feature. */
const FEATURED = {
  title: "28 Years Later",
  tagline: "The infection evolved. So did the world.",
  youtubeId: "UdRkVQVoM1U",
  channelUrl: "https://www.youtube.com/@SonyPictures",
  context: "Danny Boyle and Alex Garland return to the world of 28 Days Later — in theaters June 20.",
} as const;

const nav = [
  { label: "Trailers", href: "#" },
  { label: "Reviews", href: "#" },
  { label: "Lists", href: "#" },
  { label: "Community", href: "#" },
] as const;
---

<BaseLayout
  title="The Last Frame — Horror & sci-fi trailers, curated"
  description="Community-driven archive of horror and sci-fi: official trailer embeds, reviews, and ranked lists."
>
  <div class="shell">
    <header class="masthead">
      <div class="masthead-inner">
        <a class="brand" href="/" aria-label="The Last Frame home">
          <svg class="logo" viewBox="0 0 44 44" aria-hidden="true">
            <rect width="44" height="44" fill="#141110"></rect>
            <rect x="10" y="12" width="24" height="16" fill="none" stroke="#e8e0d5" stroke-width="1.2"></rect>
            <path d="M18 17l9 5.5-9 5.5V17z" fill="#c47a7a"></path>
          </svg>
          <div class="wordmark">
            <span class="name">The Last Frame</span>
            <span class="tagline">Horror · Science fiction · Discussion</span>
          </div>
        </a>
        <nav class="nav" aria-label="Primary">
          {nav.map((item) => (
            <a class="nav-link" href={item.href}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <div class="page">
      <main class="main">
        <section class="hero">
          <p class="issue">Vol. 1 · Est. 2026</p>
          <h1 class="headline">
            <span class="headline-line">Stop doom-scrolling trailers.</span>
            <span class="headline-line headline-line--accent">Start with context.</span>
          </h1>
          <div class="intro">
            <p class="dropcap">
              Official embeds only—then we add reviews, ranked lists, and the arguments that make genre fandom fun.
              Everything here is built to send you back to <em>studios and channels</em>, not to random reuploads.
            </p>
            <aside class="pullquote" aria-label="Principles">
              <blockquote>
                <p>“The last frame” is the one people remember. We’re cataloging the ones worth fighting over.</p>
              </blockquote>
            </aside>
          </div>
        </section>

        <section class="feature" aria-labelledby="feature-heading">
          <div class="feature-bar">
            <h2 id="feature-heading" class="feature-kicker">Front page / Featured trailer</h2>
            <span class="stamp">Coming soon to theaters</span>
          </div>

          <article class="poster">
            <header class="poster-head">
              <h3 class="film-title">{FEATURED.title}</h3>
              <p class="film-tagline">{FEATURED.tagline}</p>
              <p class="film-context">{FEATURED.context}</p>
            </header>
            <div class="embed-frame">
              <div class="embed-aspect">
                <iframe
                  title={`${FEATURED.title} — official trailer (YouTube)`}
                  src={`https://www.youtube-nocookie.com/embed/${FEATURED.youtubeId}?rel=0&modestbranding=1`}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              </div>
            </div>
            <footer class="poster-foot">
              <p class="credit">
                Trailer via
                <a href={FEATURED.channelUrl} target="_blank" rel="noopener noreferrer">Sony Pictures (YouTube)</a>.
                If you watch anywhere, watch it from the distributor’s official channel.
              </p>
            </footer>
          </article>
        </section>
      </main>

      <footer class="footer">
        <div class="footer-inner">
          <strong class="footer-name">The Last Frame</strong>
          <p class="footer-note">A reader-supported archive. No algorithmic For You page—just taste, text, and trailers.</p>
        </div>
      </footer>
    </div>
  </div>
</BaseLayout>

<style>
  .shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .masthead {
    background: #141110;
    color: #e8e0d5;
    border-bottom: 4px solid #8f1d1d;
  }

  .masthead-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1rem clamp(1rem, 3vw, 1.75rem);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    text-decoration: none;
    color: inherit;
  }

  .logo {
    width: 2.85rem;
    height: 2.85rem;
    flex-shrink: 0;
  }

  .wordmark {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .name {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 700;
    font-size: 1.35rem;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .tagline {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.72;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1.1rem;
    align-items: center;
  }

  .nav-link {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #e8e0d5;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    transition:
      border-color 0.15s ease,
      opacity 0.15s ease;
    opacity: 0.88;
  }

  .nav-link:hover {
    border-color: #c47a7a;
    opacity: 1;
  }

  .page {
    flex: 1;
    max-width: 48rem;
    margin: 0 auto;
    padding: clamp(1.75rem, 5vw, 3rem) clamp(1rem, 4vw, 2rem) 0;
    width: 100%;
  }

  .main {
    padding-bottom: 2.5rem;
  }

  .hero {
    margin-bottom: 2.75rem;
  }

  .issue {
    margin: 0 0 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #5c4d45;
  }

  .headline {
    margin: 0 0 1.75rem;
    font-family: "Fraunces", Georgia, serif;
    font-weight: 600;
    font-size: clamp(2rem, 6vw, 3.1rem);
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: #141110;
  }

  .headline-line {
    display: block;
  }

  .headline-line--accent {
    color: #8f1d1d;
    font-style: italic;
    font-weight: 500;
  }

  .intro {
    display: grid;
    gap: 1.75rem;
  }

  @media (min-width: 640px) {
    .intro {
      grid-template-columns: 1fr minmax(11rem, 14rem);
      align-items: start;
    }
  }

  .dropcap {
    margin: 0;
    font-size: 1.08rem;
    color: #2d2420;
    max-width: 38rem;
  }

  .dropcap::first-letter {
    float: left;
    font-family: "Fraunces", Georgia, serif;
    font-size: 3.4rem;
    line-height: 0.85;
    padding-right: 0.45rem;
    padding-top: 0.1rem;
    font-weight: 700;
    color: #8f1d1d;
  }

  .dropcap em {
    font-style: italic;
  }

  .pullquote {
    border: 2px solid #141110;
    background: #f3eee8;
    padding: 1rem 1.1rem;
    box-shadow: 4px 4px 0 #141110;
  }

  .pullquote blockquote {
    margin: 0;
  }

  .pullquote p {
    margin: 0;
    font-family: "Fraunces", Georgia, serif;
    font-size: 1rem;
    line-height: 1.45;
    font-style: italic;
    color: #1a1614;
  }

  .feature {
    margin-top: 0.5rem;
  }

  .feature-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.65rem;
    border-bottom: 2px solid #141110;
  }

  .feature-kicker {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #141110;
  }

  .stamp {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #e8e0d5;
    background: #8f1d1d;
    padding: 0.35rem 0.65rem;
    border: 2px solid #141110;
    transform: rotate(-1.5deg);
  }

  .poster {
    border: 3px solid #141110;
    background: #f3eee8;
    box-shadow: 8px 8px 0 rgba(20, 17, 16, 0.12);
  }

  .poster-head {
    padding: 1.35rem 1.35rem 0;
  }

  .film-title {
    margin: 0 0 0.4rem;
    font-family: "Fraunces", Georgia, serif;
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #141110;
  }

  .film-tagline {
    margin: 0 0 0.75rem;
    font-size: 1.05rem;
    font-style: italic;
    color: #3d332e;
  }

  .film-context {
    margin: 0;
    font-size: 0.92rem;
    color: #5c4d45;
  }

  .embed-frame {
    margin-top: 1.35rem;
    padding: 0 1.35rem;
  }

  .embed-aspect {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #0a0908;
    border: 3px solid #141110;
    box-shadow: inset 0 0 0 1px rgba(232, 224, 213, 0.06);
  }

  .embed-aspect iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .poster-foot {
    padding: 1rem 1.35rem 1.35rem;
  }

  .credit {
    margin: 0;
    font-size: 0.8rem;
    color: #5c4d45;
    line-height: 1.55;
  }

  .footer {
    margin-top: auto;
    background: #141110;
    color: #c4b8ad;
    border-top: 4px solid #8f1d1d;
  }

  .footer-inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 1.5rem clamp(1rem, 4vw, 2rem) 2rem;
  }

  .footer-name {
    font-family: "Fraunces", Georgia, serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: #e8e0d5;
    display: block;
    margin-bottom: 0.35rem;
  }

  .footer-note {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
    max-width: 36rem;
    opacity: 0.92;
  }

  @media (prefers-reduced-motion: reduce) {
    .stamp {
      transform: none;
    }
  }
</style>
