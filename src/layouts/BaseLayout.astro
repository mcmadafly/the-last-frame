---
import "../styles/global.css";

interface Props {
  title?: string;
  metaDescription?: string;
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
  ogImage?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
}

const {
  title = "The Last Frame — Horror & science fiction cinema",
  metaDescription = "The Last Frame covers horror and science fiction film — new releases, upcoming genre picks, and editorial. We only cover horror and sci-fi.",
  canonicalUrl = "https://thelastframe.io/",
  ogTitle = "The Last Frame — Horror & science fiction cinema",
  ogDescription = "The Last Frame covers horror and science fiction film — new releases, upcoming genre picks, and editorial.",
  ogUrl = "https://thelastframe.io/",
  ogImage = "https://image.tmdb.org/t/p/w1280/mCpwRayjXMFzKHbjbzc5JRKfq1O.jpg",
  twitterTitle = "The Last Frame — Horror & science fiction cinema",
  twitterDescription = "The Last Frame covers horror and science fiction film — new releases, upcoming genre picks, and editorial.",
  twitterImage = "https://image.tmdb.org/t/p/w1280/mCpwRayjXMFzKHbjbzc5JRKfq1O.jpg",
} = Astro.props;

const jsonLdDefault = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "The Last Frame",
      description: "Horror and science fiction cinema.",
      url: "https://thelastframe.io/",
    },
  ],
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" id="meta-description" content={metaDescription} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#080808" />
    <link rel="canonical" id="canonical-link" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="The Last Frame" />
    <meta property="og:title" id="og-title" content={ogTitle} />
    <meta property="og:description" id="og-description" content={ogDescription} />
    <meta property="og:url" id="og-url" content={ogUrl} />
    <meta property="og:image" id="og-image" content={ogImage} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" id="tw-title" content={twitterTitle} />
    <meta name="twitter:description" id="tw-description" content={twitterDescription} />
    <meta name="twitter:image" id="tw-image" content={twitterImage} />
    <script type="application/ld+json" id="jsonld-block" set:html={jsonLdDefault}></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Bebas+Neue&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
